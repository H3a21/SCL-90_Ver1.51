[
{"id":1,"text":"头痛","category":"躯体化"},
{"id":2,"text":"神经过敏，心中不踏实","category":"焦虑"},
{"id":3,"text":"头脑中有不必要的想法或字句盘旋","category":"强迫症状"},
{"id":4,"text":"头晕或昏倒","category":"躯体化"},
{"id":5,"text":"对异性的兴趣减退","category":"人际敏感"},
{"id":6,"text":"对旁人责备求全","category":"人际敏感"},
{"id":7,"text":"感到别人能控制你的思想","category":"偏执"},
{"id":8,"text":"责怪别人制造麻烦","category":"敌对"},
{"id":9,"text":"忘性大","category":"强迫症状"},
{"id":10,"text":"担心自己的衣饰整齐及仪态端正","category":"强迫症状"},
{"id":11,"text":"容易烦恼和激动","category":"抑郁"},
{"id":12,"text":"胸痛","category":"躯体化"},
{"id":13,"text":"害怕空旷的场所或街道","category":"恐怖"},
{"id":14,"text":"感到自己的精力下降，活动减慢","category":"抑郁"},
{"id":15,"text":"想结束自己的生命","category":"抑郁"},
{"id":16,"text":"听到旁人听不到的声音","category":"精神病性"},
{"id":17,"text":"发抖","category":"焦虑"},
{"id":18,"text":"感到大多数人都不可信任","category":"偏执"},
{"id":19,"text":"胃口不好","category":"躯体化"},
{"id":20,"text":"容易哭泣","category":"抑郁"},
{"id":21,"text":"同异性相处时感到害羞不自在","category":"人际敏感"},
{"id":22,"text":"感到受骗，中了圈套或有人想抓住你","category":"偏执"},
{"id":23,"text":"无缘无故地突然感到害怕","category":"焦虑"},
{"id":24,"text":"自己不能控制地大发脾气","category":"敌对"},
{"id":25,"text":"怕单独出门","category":"恐怖"},
{"id":26,"text":"经常责怪自己","category":"抑郁"},
{"id":27,"text":"腰痛","category":"躯体化"},
{"id":28,"text":"感到难以完成任务","category":"抑郁"},
{"id":29,"text":"感到孤独","category":"抑郁"},
{"id":30,"text":"感到苦闷","category":"抑郁"},
{"id":31,"text":"过分担忧","category":"焦虑"},
{"id":32,"text":"对事物不感兴趣","category":"抑郁"},
{"id":33,"text":"感到害怕","category":"焦虑"},
{"id":34,"text":"你的感情容易受到伤害","category":"人际敏感"},
{"id":35,"text":"旁人能知道你的私下想法","category":"偏执"},
{"id":36,"text":"感到别人不理解你不同情你","category":"人际敏感"},
{"id":37,"text":"感到人们对你不友好，不喜欢你","category":"人际敏感"},
{"id":38,"text":"做事必须做得很慢以保证做得正确","category":"强迫症状"},
{"id":39,"text":"心跳得很厉害","category":"焦虑"},
{"id":40,"text":"恶心或胃部不适","category":"躯体化"},
{"id":41,"text":"感到比不上他人","category":"人际敏感"},
{"id":42,"text":"肌肉酸痛","category":"躯体化"},
{"id":43,"text":"感到有人在监视你","category":"偏执"},
{"id":44,"text":"难以入睡","category":"焦虑"},
{"id":45,"text":"做事必须反复检查","category":"强迫症状"},
{"id":46,"text":"难以作出决定","category":"强迫症状"},
{"id":47,"text":"怕乘电车、公共汽车、地铁或火车","category":"恐怖"},
{"id":48,"text":"呼吸有困难","category":"焦虑"},
{"id":49,"text":"一阵阵发冷或发热","category":"躯体化"},
{"id":50,"text":"因为感到害怕而回避某些东西或场合","category":"恐怖"},
{"id":51,"text":"脑子变空了","category":"强迫症状"},
{"id":52,"text":"身体发麻或刺痛","category":"躯体化"},
{"id":53,"text":"喉咙有梗塞感","category":"躯体化"},
{"id":54,"text":"感到前途没有希望","category":"抑郁"},
{"id":55,"text":"不能集中注意力","category":"强迫症状"},
{"id":56,"text":"感到身体的某一部分软弱无力","category":"躯体化"},
{"id":57,"text":"感到紧张或容易紧张","category":"焦虑"},
{"id":58,"text":"感到手或脚发重","category":"躯体化"},
{"id":59,"text":"想到死亡的事","category":"抑郁"},
{"id":60,"text":"吃得太多","category":"其他"},
{"id":61,"text":"当别人看着你或谈论你时感到不自在","category":"人际敏感"},
{"id":62,"text":"有一些不属于你自己的想法","category":"精神病性"},
{"id":63,"text":"有想打人或伤害他人的冲动","category":"敌对"},
{"id":64,"text":"醒得太早","category":"抑郁"},
{"id":65,"text":"必须反复洗手、点数","category":"强迫症状"},
{"id":66,"text":"睡得不稳不深","category":"焦虑"},
{"id":67,"text":"有想摔坏或破坏东西的冲动","category":"敌对"},
{"id":68,"text":"有一些别人没有的想法或念头","category":"精神病性"},
{"id":69,"text":"感到对别人神经过敏","category":"人际敏感"},
{"id":70,"text":"在商店或电影院等人多的地方感到不自在","category":"恐怖"},
{"id":71,"text":"感到一切都很困难","category":"抑郁"},
{"id":72,"text":"一阵阵恐惧或惊恐","category":"焦虑"},
{"id":73,"text":"感到在公共场合吃东西很不舒服","category":"人际敏感"},
{"id":74,"text":"经常与人争论","category":"敌对"},
{"id":75,"text":"单独一人时神经很紧张","category":"焦虑"},
{"id":76,"text":"别人对你的成绩没有作出恰当的评价","category":"偏执"},
{"id":77,"text":"即使和别人在一起也感到孤独","category":"抑郁"},
{"id":78,"text":"感到坐立不安心神不定","category":"焦虑"},
{"id":79,"text":"感到自己没有什么价值","category":"抑郁"},
{"id":80,"text":"感到熟悉的东西变得陌生或不真实","category":"精神病性"},
{"id":81,"text":"大叫或摔东西","category":"敌对"},
{"id":82,"text":"害怕会在公共场合晕倒","category":"恐怖"},
{"id":83,"text":"感到别人想占你的便宜","category":"偏执"},
{"id":84,"text":"为一些有关性的想法而很苦恼","category":"强迫症状"},
{"id":85,"text":"你认为应该因为自己的过错而受到惩罚","category":"抑郁"},
{"id":86,"text":"感到要很快把事情做完","category":"焦虑"},
{"id":87,"text":"感到自己的身体有严重问题","category":"躯体化"},
{"id":88,"text":"从未感到和其他人很亲近","category":"人际敏感"},
{"id":89,"text":"感到自己有罪","category":"抑郁"},
{"id":90,"text":"感到自己的脑子有毛病","category":"精神病性"}
]